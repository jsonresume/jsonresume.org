{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "**/public/**",
    "apps/registry/app/api/chat/config/resumeToolSchema/**"
  ],
  "ignoreDependencies": [
    "@vitejs/plugin-react",
    "@storybook/react",
    "json-to-pretty-yaml"
  ],
  "ignoreWorkspaces": [
    "packages/themes/**",
    "packages/resume-core",
    "packages/converters/**",
    "packages/core-rust"
  ],
  "workspaces": {
    "apps/registry": {
      "entry": [
        "app/**/page.{js,jsx,ts,tsx}",
        "app/**/layout.{js,jsx,ts,tsx}",
        "app/**/route.{js,jsx,ts,tsx}",
        "app/**/{loading,error,not-found,template,default}.{js,jsx,ts,tsx}",
        "middleware.{js,ts}",
        "next.config.{js,mjs,ts}",
        "scripts/**/*.{js,mjs}",
        "**/*.test.{js,jsx,ts,tsx}"
      ]
    },
    "apps/homepage2": {
      "entry": [
        "app/**/page.{js,jsx,ts,tsx}",
        "app/**/layout.{js,jsx,ts,tsx}",
        "pages/**/*.{js,jsx,ts,tsx}",
        "next.config.{js,mjs,ts}",
        "tests/**/*.spec.{js,ts}"
      ]
    },
    "apps/docs": {
      "entry": [
        "app/**/page.{js,jsx,ts,tsx}",
        "app/**/layout.{js,jsx,ts,tsx}",
        "source.config.ts",
        "next.config.{js,mjs,ts}"
      ]
    },
    "packages/cli": {
      "entry": [
        "lib/main.js",
        "lib/**/*.test.js",
        "lib/test-utils/cli-test-entry.js"
      ]
    }
  }
}
