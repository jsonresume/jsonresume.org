# ==============================================
# JSON Resume Registry - Environment Variables
# ==============================================

# ==================
# Authentication
# ==================

# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers
AUTH_GITHUB_ID=your_github_oauth_app_id
AUTH_GITHUB_SECRET=your_github_oauth_app_secret

# NextAuth.js configuration
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_key
NEXTAUTH_URL=http://localhost:3000

# Auth.js v5 configuration
AUTH_SECRET=your_auth_secret_key
AUTH_URL=http://localhost:3000

# ==================
# Database (Supabase)
# ==================

# Supabase Project URL and Keys
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_KEY=your_supabase_service_role_key

# ==================
# AI Services
# ==================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# Perplexity AI API Key (optional)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key

# ==================
# GitHub Integration
# ==================

# GitHub Personal Access Token (for API access)
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, user
GITHUB_TOKEN=ghp_your_github_personal_access_token

# ==================
# Database (Direct)
# ==================

# Direct PostgreSQL connection URLs (Supabase)
DATABASE_URL=postgresql://user:password@host:5432/postgres
DATABASE_URL_RAW=postgresql://user:password@host:5432/postgres

# ==================
# Vector Search (Pinecone)
# ==================

# Pinecone API key and environment
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=your_pinecone_environment

# ==================
# Application
# ==================

# Public application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==================
# Logging
# ==================

# Log level for Pino logger
# Options: trace, debug, info, warn, error, fatal
# Default: info in production, debug in development
LOG_LEVEL=debug

# Logtail / Better Stack (optional)
# Get from: https://betterstack.com
LOGTAIL_SOURCE_TOKEN=your_logtail_source_token
LOGTAIL_URL=https://in.logs.betterstack.com
NEXT_PUBLIC_LOGTAIL_SOURCE_TOKEN=your_logtail_source_token
NEXT_PUBLIC_BETTER_STACK_SOURCE_TOKEN=your_better_stack_source_token
NEXT_PUBLIC_BETTER_STACK_INGESTING_URL=https://in.logs.betterstack.com

# ==================
# Monitoring & Notifications
# ==================

# Discord Webhook URL (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ==================
# Vercel (Optional)
# ==================

# Bypass fallback oversized error (set by Vercel)
# VERCEL_BYPASS_FALLBACK_OVERSIZED_ERROR=1
