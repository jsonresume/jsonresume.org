    "theme-metadata",
    "theme-gallery",
    "config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jsonresume/jsonresume.org",
    "directory": "packages/theme-config"
  },
  "homepage": "https://github.com/jsonresume/jsonresume.org/tree/master/packages/theme-config",
