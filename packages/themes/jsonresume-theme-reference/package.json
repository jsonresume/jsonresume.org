{
  "name": "jsonresume-theme-reference",
  "version": "0.2.4",
  "description": "Reference theme demonstrating @resume/core best practices - ATS-friendly, framework-agnostic",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./src/index.jsx",
      "default": "./dist/index.js"
    },
    "./dist": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build"
  },
  "keywords": [
    "jsonresume",
    "theme",
    "resume",
    "cv",
    "ats-friendly",
    "reference"
  ],
  "dependencies": {
    "@jsonresume/core": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "vitest": "^3.2.6",
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.4.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
