{
  "name": "jsonresume-theme-desert-modern",
  "version": "0.1.4",
  "description": "Warm minimalist resume theme inspired by desert modern aesthetics",
  "main": "./dist/index.js",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "jsonresume",
    "theme",
    "desert",
    "minimalist",
    "modern"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@jsonresume/core": "workspace:*",
    "styled-components": "^6.1.19"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "exports": {
    ".": {
      "import": "./src/index.jsx",
      "default": "./dist/index.js"
    },
    "./dist": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.4.3",
    "@jsonresume/sample-data": "workspace:*",
    "@jsonresume/theme-kit": "workspace:*",
    "vitest": "^3.2.6"
  }
}
