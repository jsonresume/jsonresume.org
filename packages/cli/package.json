{
  "name": "resume-cli",
  "version": "3.7.0",
  "description": "The JSON Resume command line interface",
  "main": "build/main.js",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "build/*",
    "!test-utils",
    "!*.test.js"
  ],
  "scripts": {
    "dev": "babel-node lib/main.js",
    "lint": "eslint --ignore-path .gitignore .",
    "build": "babel lib -d build --copy-files",
    "prepare": "babel lib -d build --copy-files",
    "test": "jest"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jsonresume/resume-cli.git"
  },
  "license": "MIT",
  "bin": {
    "resume": "build/main.js"
  },
  "dependencies": {
    "@jsonresume/ats-validator": "workspace:*",
    "@jsonresume/schema": "workspace:*",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "async": "^3.2.0",
    "browser-sync": "^2.29.3",
    "btoa": "^1.2.1",
    "chalk": "^4.1.0",
    "commander": "^6.0.0",
    "dotenv": "^8.2.0",
    "file-exists": "^5.0.1",
    "jest-extended": "^0.11.5",
    "jsonresume-theme-elegant": "^1.16.1",
    "jsonresume-theme-even": "0.6.0",
    "mime-types": "^2.1.27",
    "object-path-immutable": "^4.1.1",
    "puppeteer": "^23.0.0",
    "quaff": "^4.2.0",
    "read": "^1.0.7",
    "stream-to-string": "^1.2.1",
    "superagent": "^6.0.0",
    "yaml-js": "^0.2.3",
    "yesno": "^0.3.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.25.0",
    "@babel/core": "^7.25.0",
    "@babel/eslint-parser": "^7.25.0",
    "@babel/node": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "babel-jest": "^29.7.0",
    "dedent": "0.7.0",
    "eslint": "7.15.0",
    "eslint-config-prettier": "7.0.0",
    "eslint-plugin-jest": "24.1.3",
    "eslint-plugin-prettier": "3.2.0",
    "flat": "5.0.2",
    "fs-monkey": "1.0.1",
    "jest": "^29.7.0",
    "memfs": "3.6.0",
    "mock-stdin": "1.0.0",
    "prettier": "2.2.1",
    "unionfs": "4.4.0",
    "waait": "1.0.5"
  }
}
