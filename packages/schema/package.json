{
  "name": "@jsonresume/schema",
  "version": "1.3.1",
  "description": "JSON Resume Schema",
  "private": false,
  "main": "validator.js",
  "scripts": {
    "test": "npm run validate && npm run test-units",
    "validate": "ajv validate -s node_modules/json-metaschema/draft-07-schema -d schema -d job-schema",
    "test-units": "tape **/*.spec.js | tap-spec"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsonresume/jsonresume.org.git",
    "directory": "packages/schema"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jsonresume/jsonresume.org/issues"
  },
  "files": [
    "sample.resume.json",
    "sample.job.json",
    "schema.json",
    "job-schema.json",
    "validator.js",
    "examples"
  ],
  "dependencies": {
    "jsonschema": "^1.4.1"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-cli": "^3.3.0",
    "ajv-formats": "^3.0.1",
    "json-metaschema": "^1.3.0",
    "tap-spec": "^5.0.0",
    "tape": "^4.16.2"
  },
  "engines": {
    "node": ">=20"
  }
}
